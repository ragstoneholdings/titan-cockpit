# Copy to `.env` at the repo root (gitignored). Loaded by `integrations/env_loader.py` at API startup.
# Docker: bind-mount the repo (`docker compose`) so `/app/.env` is this file after copy.

# --- API auth (Phase 3) — when set, all routes except GET /api/health require X-Cockpit-Key or Bearer ---
# COCKPIT_API_KEY=
# Optional: forbid GET /api/device/tokens when COCKPIT_API_KEY is unset (stricter prod)
# COCKPIT_BLOCK_DEVICE_TOKENS_WITHOUT_KEY=1

# --- Mutable JSON state (Phase 6) — set on production hosts to a persistent volume path, e.g. /data ---
# RAGSTONE_DATA_ROOT=/data

# --- CORS (comma-separated origins for browser clients) ---
# ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Apple Push Notification service (Phase 8) — server-side send; .p8 from Apple Developer ---
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.ragstone.vanguard.cockpit
# APNS_KEY_PATH=/path/to/AuthKey_XXXXXX.p8
# APNS_USE_SANDBOX=true

# --- Todoist / Power Trio ---
# TODOIST_API_KEY=

# --- Gemini (cockpit LLM, ranking, windshield) ---
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Identity / strategy (optional; identity.json also used) ---
# POWER_PURPOSE_STATEMENT=
# POWER_RAGSTONE_STRATEGY=
# POWER_SCALED_OPS=
# POWER_IDENTITY_PROJECT_SUBSTRINGS=Ragstone,Home,Titan
# POWER_GOOGLE_OPS_SUBSTRINGS=Google,Work

# --- Google Calendar OAuth (paths under repo root unless overridden) ---
# GOOGLE_CALENDAR_CREDENTIALS=
# COCKPIT_FRONTEND_URL=http://localhost:5173

# --- Personal / iCloud calendar (optional) ---
# APPLE_CALENDAR_ICS_URL=
# ICLOUD_APPLE_ID=
# ICLOUD_APP_PASSWORD=
# ICLOUD_CALENDAR_NAME=

# --- Cockpit operator / shields (server-side schedule hints for snapshot) ---
# COCKPIT_OPERATOR_NAME=
# AIR_GAP_START_HOUR=8
# AIR_GAP_END_HOUR=9
# MIDDAY_SHIELD_START_HOUR=12
# MIDDAY_SHIELD_END_HOUR=13
# IDENTITY_ALIGNMENT_START_HOUR=7
# IDENTITY_ALIGNMENT_END_HOUR=8
