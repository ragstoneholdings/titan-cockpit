# Copy to secrets.toml in this folder, then add your key:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
GEMINI_API_KEY = "your-key-here"
# Optional — default is gemini-2.5-flash. For heavier reasoning: gemini-2.5-pro
# GEMINI_MODEL = "gemini-2.5-flash"

# Optional live Todoist (or use env: TODOIST_API_KEY)
# TODOIST_API_KEY = "your-token"
# Pull uses Todoist filters: today, overdue, and Next Focus (below). Default Next Focus: @next & @focus
# TODOIST_NEXT_FOCUS_FILTER = "@next & @focus"

# Personal Apple Calendar (optional) — either iCloud CalDAV or a read-only ICS / webcal URL
# ICLOUD_APPLE_ID = "you@icloud.com"
# ICLOUD_APP_PASSWORD = "xxxx-xxxx-xxxx-xxxx"  # app-specific password from appleid.apple.com
# ICLOUD_CALENDAR_NAME = "Personal"   # optional substring to pick one calendar among many
# APPLE_CALENDAR_ICS_URL = "https://..."  # or webcal://... from Calendar.app → share
